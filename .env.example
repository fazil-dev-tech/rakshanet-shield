# =============================================================
# RakshaNet Shield — Environment Variables
# =============================================================
# Copy this file to `.env.local` and fill in your credentials.
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to version control!
# =============================================================

# --- Supabase Configuration ---
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Live Threat Intelligence ---
# Get your API key from: https://cyberbriefing.info
NEXT_PUBLIC_CYBERBRIEFING_API_KEY=your_cyberbriefing_api_key_here
